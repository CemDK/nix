#!/usr/bin/env bash
# Based on the primeagens tmux-sessionizer

[[ $1 == "--debug" ]] && set -x

# Name of the session we're running from, so we can filter it out below
current_session=""
[[ -n "$TMUX" ]] && current_session=$(tmux display-message -p '#S')

# Collect candidate directories and prompt with fzf
selected=$(
  {
    echo "$HOME/.config/nix"
    echo "$HOME/.config/nvim"
    find ~/dev/personal ~/dev/git ~/dev/public -mindepth 1 -maxdepth 1 -type d 2>/dev/null
    find ~/dev/work -mindepth 2 -maxdepth 2 -type d 2>/dev/null
  } | sort | while IFS= read -r dir; do
      # Skip the dir whose derived session name matches the current session
      name=$(basename "$dir" | tr ";,. " "____")
      [[ -n "$current_session" && "$name" == "$current_session" ]] && continue
      printf '%s\n' "$dir"
    done | fzf --tmux='80%' --preview-window='50%,right' --layout=reverse --preview='eza --tree --colour=always {}'
)

# Exit if nothing was selected
[[ -z "$selected" ]] && exit 0

# Derive a session name from the directory basename
selected_name=$(basename "$selected" | tr ";,. " "____")

# Create the session if it doesn't already exist
if ! tmux has-session -t="$selected_name" 2>/dev/null; then
  tmux new-session -ds "$selected_name" -c "$selected"
  tmux send-keys -t "$selected_name" "ready-tmux" ^M
fi

# Attach or switch depending on whether we're inside tmux
if [[ -z "$TMUX" ]]; then
  tmux attach-session -t "$selected_name"
else
  tmux switch-client -t "$selected_name"
fi
